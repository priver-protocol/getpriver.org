---
import { footer } from "../../data/footer";
const year = new Date().getFullYear();
const copyright = footer.copyrightTemplate.replace("{year}", String(year));
---

<footer class="border-t border-zinc-200 bg-zinc-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid md:grid-cols-2 gap-10 items-start">
      <div>
        <a href="/" class="inline-block group">
          <img
            src={footer.logo.src}
            alt={footer.logo.alt}
            class="h-7 w-auto group-hover:opacity-80 transition"
          />
        </a>
        <p
          class="mt-5 max-w-md text-zinc-700 text-sm leading-relaxed"
          set:html={footer.taglineHtml}
        />
        <p class="mt-3 text-sm text-zinc-500">
          {footer.credit}
        </p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-6 text-sm">
        {
          footer.columns.map((col) => (
            <div>
              <h4 class="text-xs font-semibold uppercase tracking-widest text-zinc-500">
                {col.heading}
              </h4>
              <ul class="mt-4 space-y-2">
                {col.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="text-zinc-700 hover:text-zinc-900"
                      {...(link.external
                        ? { target: "_blank", rel: "noopener noreferrer" }
                        : {})}
                    >
                      {link.text}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
    <div
      class="mt-12 pt-6 border-t border-zinc-200 flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between text-xs text-zinc-500"
    >
      <p>{copyright}</p>
      <p>{footer.legal}</p>
    </div>
  </div>
</footer>
