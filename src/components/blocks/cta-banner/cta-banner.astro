---
import Button from "../../ui/Button.astro";
import SectionLabel from "../../ui/SectionLabel.astro";
import Markdown from "../../ui/Markdown.astro";
import type { ButtonData } from "../../../lib/schemas";

interface Props {
  label?: string;
  heading: string;
  description: string;
  button: ButtonData;
}

const { label, heading, description, button } = Astro.props;
---

<section class="relative border-t border-zinc-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div
      class="relative overflow-hidden rounded-3xl border border-priver-200 bg-gradient-to-br from-priver-50 via-white to-white p-8 sm:p-12"
    >
      <div
        aria-hidden="true"
        class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-priver-200/50 blur-3xl"
      >
      </div>
      <div class="relative grid lg:grid-cols-[1fr_auto] gap-8 items-center">
        <div>
          {label && <SectionLabel text={label} />}
          <h2
            class="mt-3 text-3xl sm:text-4xl font-extrabold tracking-tight text-zinc-900"
          >
            {heading}
          </h2>
          <Markdown
            as="p"
            inline
            content={description}
            class="mt-6 max-w-2xl text-zinc-700 leading-relaxed"
          />
        </div>
        <div>
          <Button
            href={button.href}
            text={button.text}
            variant={button.variant}
            size={button.size}
            iconLeft={button.icon_left}
            iconRight={button.icon_right}
            external={button.external}
            platformLabel={button.platform_label}
          />
        </div>
      </div>
    </div>
  </div>
</section>
