---
import { Icon } from "astro-icon/components";
import Heading from "../../ui/Heading.astro";
import Markdown from "../../ui/Markdown.astro";
import SectionLabel from "../../ui/SectionLabel.astro";

interface ScenarioCard {
  icon: string;
  scenario: string;
  without: string;
  with_priver: string;
}

interface Props {
  id?: string;
  background?: "white" | "zinc-50";
  label?: string;
  heading?: string;
  description?: string;
  cards: ScenarioCard[];
  closer?: string;
}

const {
  id,
  background = "white",
  label,
  heading,
  description,
  cards,
  closer,
} = Astro.props;

const bgClass = background === "zinc-50" ? "bg-zinc-50" : "";
---

<section
  id={id}
  class:list={["relative border-t border-zinc-200", bgClass]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    {
      (label || heading || description) && (
        <div class="max-w-4xl">
          {label && <SectionLabel text={label} />}
          {heading && (
            <Heading level="h2" size="section" text={heading} class="mt-4" />
          )}
          {description && (
            <Markdown
              as="p"
              inline
              content={description}
              class="mt-6 text-lg text-zinc-700 leading-relaxed"
            />
          )}
        </div>
      )
    }

    <div class="mt-12 space-y-4">
      {
        cards.map((card) => (
          <div class="rounded-2xl border border-zinc-200 bg-white p-6 sm:p-8">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-brand-gradient-br flex items-center justify-center">
                <Icon
                  name={card.icon}
                  class="w-5 h-5 text-white"
                  aria-hidden="true"
                />
              </div>
              <h3 class="mt-1.5 text-lg font-semibold text-zinc-900">
                {card.scenario}
              </h3>
            </div>
            <div class="mt-6 grid sm:grid-cols-2 gap-4">
              <div class="rounded-xl border border-red-200 bg-red-50/50 p-5">
                <p class="text-xs font-semibold uppercase tracking-widest text-red-600">
                  Without Priver
                </p>
                <Markdown
                  as="p"
                  inline
                  content={card.without}
                  class="mt-3 text-sm text-zinc-700 leading-relaxed"
                />
              </div>
              <div class="rounded-xl border border-emerald-200 bg-emerald-50/50 p-5">
                <p class="text-xs font-semibold uppercase tracking-widest text-emerald-600">
                  With Priver
                </p>
                <Markdown
                  as="p"
                  inline
                  content={card.with_priver}
                  class="mt-3 text-sm text-zinc-700 leading-relaxed"
                />
              </div>
            </div>
          </div>
        ))
      }
    </div>

    {
      closer && (
        <Markdown
          as="p"
          inline
          content={closer}
          class="mt-12 max-w-3xl text-lg text-zinc-700 leading-relaxed"
        />
      )
    }
  </div>
</section>
