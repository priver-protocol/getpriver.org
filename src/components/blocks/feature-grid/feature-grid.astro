---
import { Icon } from "astro-icon/components";
import Heading from "../../ui/Heading.astro";
import Markdown from "../../ui/Markdown.astro";
import SectionLabel from "../../ui/SectionLabel.astro";
import type { CardData } from "../../../lib/schemas";

interface Props {
  id?: string;
  background?: "white" | "zinc-50";
  label?: string;
  heading?: string;
  description?: string;
  bullets?: Array<{ text: string }>;
  subheading?: string;
  columns?: 2 | 3 | 5;
  cards: CardData[];
  closing?: { primary: string; secondary?: string };
}

const {
  id,
  background = "white",
  label,
  heading,
  description,
  bullets,
  subheading,
  columns = 3,
  cards,
  closing,
} = Astro.props;

const bgClass = background === "zinc-50" ? "bg-zinc-50" : "";

const gridCols: Record<2 | 3 | 5, string> = {
  2: "grid sm:grid-cols-2 gap-4",
  3: "grid sm:grid-cols-2 lg:grid-cols-3 gap-4",
  5: "grid sm:grid-cols-2 lg:grid-cols-5 gap-4",
};
---

<section
  id={id}
  class:list={["relative border-t border-zinc-200", bgClass]}
>
  <div
    class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32"
  >
    {
      (label || heading || description) && (
        <div class="max-w-4xl">
          {label && <SectionLabel text={label} />}
          {heading && (
            <Heading level="h2" size="section" text={heading} class="mt-4" />
          )}
          {description && (
            <Markdown
              as="p"
              inline
              content={description}
              class="mt-6 text-lg text-zinc-700 leading-relaxed"
            />
          )}
        </div>
      )
    }

    {
      bullets && bullets.length > 0 && (
        <ul class="mt-10 space-y-3">
          {bullets.map((b) => (
            <li class="flex items-center gap-3">
              <span
                aria-hidden="true"
                class="flex-shrink-0 w-2 h-2 rounded-full bg-brand-gradient-br"
              />
              <p class="text-base sm:text-lg font-semibold text-zinc-900">
                {b.text}
              </p>
            </li>
          ))}
        </ul>
      )
    }

    {
      subheading && (
        <h3 class="mt-20 text-2xl sm:text-3xl font-bold tracking-tight text-zinc-900">
          {subheading}
        </h3>
      )
    }

    <div
      class:list={[
        subheading ? "mt-8" : "mt-12",
        !heading && !label ? "mt-0" : "",
        gridCols[columns],
      ]}
    >
      {
        cards.map((card) => {
          if (card.variant === "plain") {
            // Used by the "Who it's for" 5-card grid: tighter card with no icon.
            return (
              <div class="rounded-2xl border border-zinc-200 bg-white p-6">
                <p class="text-base font-semibold text-zinc-900">
                  {card.title}
                </p>
                {card.description && (
                  <p class="mt-1 text-sm text-zinc-700">{card.description}</p>
                )}
              </div>
            );
          }

          if (card.variant === "highlight") {
            return (
              <div class="rounded-2xl border border-priver-200 bg-gradient-to-br from-priver-50 to-white p-6">
                {card.icon && (
                  <div class="w-10 h-10 rounded-lg bg-white border border-priver-200 flex items-center justify-center">
                    <Icon
                      name={card.icon}
                      class="w-5 h-5 text-priver-600"
                      aria-hidden="true"
                    />
                  </div>
                )}
                <h3 class="mt-5 text-lg font-semibold text-zinc-900">
                  {card.title}
                </h3>
                {card.description && (
                  <p class="mt-2 text-sm text-zinc-700 leading-relaxed">
                    {card.description}
                  </p>
                )}
              </div>
            );
          }

          // default
          return (
            <div class="rounded-2xl border border-zinc-200 bg-white p-6 hover:border-priver-300 hover:shadow-md hover:shadow-priver-100/50 transition">
              {card.layer_number && (
                <div class="flex items-center gap-3">
                  <span class="text-xs font-mono uppercase tracking-widest text-priver-600">
                    {card.layer_number}
                  </span>
                  {card.layer_subtitle && (
                    <span class="text-xs text-zinc-500">
                      {card.layer_subtitle}
                    </span>
                  )}
                </div>
              )}
              {card.icon && !card.layer_number && (
                <div class="w-10 h-10 rounded-lg bg-brand-gradient-br flex items-center justify-center">
                  <Icon
                    name={card.icon}
                    class="w-5 h-5 text-white"
                    aria-hidden="true"
                  />
                </div>
              )}
              <h3
                class:list={[
                  card.layer_number
                    ? "mt-4 text-2xl font-bold text-zinc-900"
                    : "mt-5 text-lg font-semibold text-zinc-900",
                ]}
              >
                {card.title}
              </h3>
              {card.description && (
                <p
                  class:list={[
                    card.layer_number
                      ? "mt-3 text-sm text-zinc-700 leading-relaxed"
                      : "mt-2 text-sm text-zinc-700 leading-relaxed",
                  ]}
                >
                  {card.description}
                </p>
              )}
            </div>
          );
        })
      }
    </div>

    {
      closing && (
        <p class="mt-12 max-w-3xl text-2xl sm:text-3xl font-bold tracking-tight text-zinc-900">
          {closing.primary}
          {closing.secondary && (
            <span class="block mt-3 text-zinc-700 font-normal text-lg sm:text-xl">
              {closing.secondary}
            </span>
          )}
        </p>
      )
    }
  </div>
</section>
