---
import { renderInline } from "../../lib/markdown";

type Level = "h1" | "h2" | "h3";
type Size = "hero" | "section" | "subsection";

interface Props {
  level?: Level;
  size?: Size;
  text: string;
  class?: string;
}

const {
  level = "h2",
  size = "section",
  text,
  class: classAttr,
} = Astro.props;

const sizeClasses: Record<Size, string> = {
  hero: "text-4xl sm:text-5xl lg:text-6xl xl:text-[5.5rem] font-extrabold tracking-tight leading-[1.05]",
  section:
    "text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.1]",
  subsection: "text-2xl sm:text-3xl font-bold tracking-tight",
};

const Tag = level;
const html = renderInline(text);
---

<Tag
  class:list={[sizeClasses[size], "text-zinc-900 heading", classAttr]}
  set:html={html}
/>

<style>
  .heading :global(strong) {
    font-weight: inherit;
    background-image: linear-gradient(
      to right,
      var(--color-priver-purple),
      var(--color-priver-blue)
    );
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
  }
  .heading :global(em) {
    font-style: normal;
    color: var(--color-zinc-600);
  }
</style>
