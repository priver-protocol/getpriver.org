---
// Decorative blurred gradient circles fixed behind page content.
---

<div
  aria-hidden="true"
  class="pointer-events-none fixed inset-0 -z-10 overflow-hidden"
>
  <div
    class="absolute -top-40 -left-40 w-[40rem] h-[40rem] rounded-full bg-priver-200/40 blur-3xl"
  >
  </div>
  <div
    class="absolute top-1/3 -right-40 w-[36rem] h-[36rem] rounded-full bg-priver-100/60 blur-3xl"
  >
  </div>
</div>
