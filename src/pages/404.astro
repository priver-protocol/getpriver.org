---
import Layout from "../layouts/Layout.astro";
import Button from "../components/ui/Button.astro";
---

<Layout title="Not found — Priver">
  <section class="relative">
    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 lg:py-40 text-center"
    >
      <p
        class="text-xs font-semibold uppercase tracking-widest text-priver-600"
      >
        Error 404
      </p>
      <h1
        class="mt-4 text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-zinc-900"
      >
        Page not <span class="text-brand-gradient">found.</span>
      </h1>
      <p class="mt-6 text-lg text-zinc-700 max-w-xl mx-auto">
        The page you're looking for doesn't exist — or it never did.
      </p>
      <div class="mt-10 flex justify-center gap-3">
        <Button
          href="/"
          text="Back to home"
          variant="primary"
          iconRight="lucide:arrow-right"
        />
        <Button href="/threat-model/" text="Threat model" variant="secondary" />
      </div>
    </div>
  </section>
</Layout>
